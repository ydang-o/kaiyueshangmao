<block wx:if="{{!isLoggedIn}}"><view class="login-banner-wrap data-v-d69631e4"><view class="login-banner tm-card data-v-d69631e4"><view class="login-banner-inner data-v-d69631e4"><text class="login-banner-text tm-text-secondary data-v-d69631e4">登录后享受完整服务</text><button class="cu-btn round tm-primary-btn data-v-d69631e4" type="button" hover-class="button-hover" loading="{{loginLoading}}" data-event-opts="{{[['tap',[['onWxLogin',['$event']]]]]}}" bindtap="__e"> 微信一键登录 </button></view></view></view></block><block wx:else><block wx:if="{{showProfileModal}}"><view data-event-opts="{{[['tap',[['closeProfileModal',['$event']]]]]}}" class="profile-modal-mask data-v-d69631e4" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="profile-modal-card tm-card data-v-d69631e4" catchtap="__e"><view class="profile-modal-title tm-section-title data-v-d69631e4">完善个人资料</view><view class="profile-modal-field data-v-d69631e4"><text class="profile-field-label tm-text-secondary data-v-d69631e4">头像</text><button class="avatar-btn data-v-d69631e4" open-type="chooseAvatar" data-event-opts="{{[['chooseavatar',[['onChooseAvatar',['$event']]]]]}}" bindchooseavatar="__e"><block wx:if="{{localAvatar}}"><image class="avatar-img data-v-d69631e4" src="{{localAvatar}}" mode="aspectFill"></image></block><block wx:else><view class="avatar-placeholder data-v-d69631e4"><text class="avatar-hint tm-text-muted data-v-d69631e4">点击选择头像</text></view></block></button></view><view class="profile-modal-field data-v-d69631e4"><text class="profile-field-label tm-text-secondary data-v-d69631e4">昵称</text><input class="nickname-input data-v-d69631e4" type="nickname" placeholder="请输入昵称" data-event-opts="{{[['blur',[['onNicknameBlur',['$event']]]],['input',[['onNicknameInput',['$event']]]]]}}" value="{{localNickname}}" bindblur="__e" bindinput="__e"/></view><view class="profile-modal-field data-v-d69631e4"><text class="profile-field-label tm-text-secondary data-v-d69631e4">电话</text><block wx:if="{{displayPhone}}"><view class="nickname-box tm-text-primary data-v-d69631e4">{{displayPhone}}</view></block><block wx:else><button class="cu-btn round block tm-primary-btn profile-modal-btn data-v-d69631e4" type="button" hover-class="button-hover" loading="{{phoneLoading}}" open-type="getPhoneNumber" data-event-opts="{{[['getphonenumber',[['onGetPhoneNumber',['$event']]]]]}}" bindgetphonenumber="__e"> 授权手机号 </button></block></view><button class="cu-btn round block tm-primary-btn profile-modal-btn profile-modal-confirm data-v-d69631e4" type="button" hover-class="button-hover" data-event-opts="{{[['tap',[['onConfirm',['$event']]]]]}}" bindtap="__e"> 确认登录 </button></view></view></block></block>