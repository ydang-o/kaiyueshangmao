<view class="cu-card article no-card data-v-3557433b"><block wx:for="{{goodsList}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="cu-item data-v-3557433b"><navigator hover-class="none" url="{{'/pages/goods/goods-detail/index?id='+item.id}}" class="data-v-3557433b"><view class="content data-v-3557433b"><image class="row-img margin-top-xs data-v-3557433b" src="{{item.picUrls&&item.picUrls[0]?item.picUrls[0]:'/static/img/no_pic.png'}}" mode="aspectFill"></image><view class="desc solid-bottom row-info data-v-3557433b"><view class="text-black margin-top-sm overflow-2 data-v-3557433b">{{item.name}}</view><view class="text-gray text-sm margin-top-sm overflow-2 data-v-3557433b">{{item.sellPoint}}</view><view class="flex justify-between margin-top-sm data-v-3557433b"><view class="text-price text-bold text-red padding-lr-sm data-v-3557433b">{{item.salesPrice}}</view><view class="text-gray text-sm padding-lr-sm data-v-3557433b">{{"已售"+item.saleNum}}</view></view><view class="flex justify-start margin-tb-sm data-v-3557433b"><block wx:if="{{item.pointsGiveSwitch=='1'}}"><view class="cu-tag bg-orange radius sm data-v-3557433b">积分</view></block></view></view></view></navigator></view></block></view>