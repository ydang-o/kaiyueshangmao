<view class="flex justify-end data-v-5b4ed546"><block wx:if="{{contact}}"><button class="cu-btn radius margin-right shadow-blur service data-v-5b4ed546" open-type="contact" data-event-opts="{{[['contact',[['handleContact',['$event']]]]]}}" bindcontact="__e"><view class="cuIcon-servicefill text-white data-v-5b4ed546"></view><text class="text-white data-v-5b4ed546">客服</text></button></block><block wx:if="{{orderInfo.status=='5'&&orderInfo.isPay=='0'}}"><button class="cu-btn radius margin-right shadow-blur delete-order data-v-5b4ed546" loading="{{loading}}" disabled="{{loading}}" data-event-opts="{{[['tap',[['orderDel',['$event']]]]]}}" bindtap="__e"><text class="text-white data-v-5b4ed546">删除订单</text></button></block><block wx:if="{{orderInfo.isPay=='0'&&!orderInfo.status}}"><button class="cu-btn radius margin-right shadow-blur cancel-order data-v-5b4ed546" loading="{{loading}}" disabled="{{loading}}" data-event-opts="{{[['tap',[['orderCancel',['$event']]]]]}}" bindtap="__e"><text class="text-white data-v-5b4ed546">取消订单</text></button></block><block wx:if="{{$root.g0}}"><button class="cu-btn radius margin-right shadow-blur check-logistics data-v-5b4ed546" loading="{{loading}}" disabled="{{loading}}" data-event-opts="{{[['tap',[['orderLogistics',['$event']]]]]}}" bindtap="__e"><text class="text-white data-v-5b4ed546">查看物流</text></button></block><block wx:if="{{orderInfo.isPay=='0'&&!orderInfo.status}}"><button class="cu-btn radius margin-right shadow-blur payment data-v-5b4ed546" loading="{{loading}}" disabled="{{loading}}" data-event-opts="{{[['tap',[['unifiedOrder',['$event']]]]]}}" bindtap="__e"><text class="text-white data-v-5b4ed546">付款</text></button></block><block wx:if="{{orderInfo.status=='2'}}"><button class="cu-btn radius margin-right shadow-blur confirm-goods data-v-5b4ed546" loading="{{loading}}" disabled="{{loading}}" data-event-opts="{{[['tap',[['orderReceive',['$event']]]]]}}" bindtap="__e"><text class="text-white data-v-5b4ed546">确认收货</text></button></block><block wx:if="{{orderInfo.status=='3'&&orderInfo.appraisesStatus=='0'}}"><button class="cu-btn radius margin-right shadow-blur evaluation data-v-5b4ed546" loading="{{loading}}" disabled="{{loading}}" data-event-opts="{{[['tap',[['orderAppraise',['$event']]]]]}}" bindtap="__e"><text class="text-white data-v-5b4ed546">评价</text></button></block></view>