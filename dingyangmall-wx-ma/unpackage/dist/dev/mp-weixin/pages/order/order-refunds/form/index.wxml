<view class="page padding data-v-5f7fffd8"><view class="bg-white padding radius data-v-5f7fffd8"><view class="cu-form-group data-v-5f7fffd8"><view class="title data-v-5f7fffd8">订单项</view><view class="text-gray data-v-5f7fffd8">{{"订单项 ID："+(orderItemId||'-')}}</view></view><block wx:if="{{orderItemId}}"><view class="cu-form-group data-v-5f7fffd8"><view class="title data-v-5f7fffd8">退款原因（选填）</view><textarea placeholder="请输入退款原因" maxlength="200" data-event-opts="{{[['input',[['__set_model',['','reason','$event',[]]]]]]}}" value="{{reason}}" bindinput="__e" class="data-v-5f7fffd8"></textarea></view></block><view class="padding flex flex-direction margin-top-xl data-v-5f7fffd8"><button class="cu-btn bg-red lg data-v-5f7fffd8" loading="{{loading}}" data-event-opts="{{[['tap',[['submit',['$event']]]]]}}" bindtap="__e">提交申请</button></view><view class="text-gray text-sm margin-top data-v-5f7fffd8">提交后将由商家审核，请耐心等待。</view></view></view>