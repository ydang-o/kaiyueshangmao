<view class="page data-v-b41f5bda"><view class="cu-list menu-avatar data-v-b41f5bda"><block wx:for="{{userAddress}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="cu-item solid-top data-v-b41f5bda"><view class="cu-avatar round bg-red data-v-b41f5bda"><text class="avatar-text data-v-b41f5bda">{{item.userName}}</text></view><view data-event-opts="{{[['tap',[['selectUserAddress',[index]]]]]}}" class="content loc-content data-v-b41f5bda" bindtap="__e"><view class="flex data-v-b41f5bda"><view class="text-black data-v-b41f5bda">{{item.userName}}</view><view class="text-gray text-sm margin-left-sm data-v-b41f5bda">{{item.telNum}}</view></view><view class="text-black text-sm overflow-2 loc-info data-v-b41f5bda"><block wx:if="{{item.isDefault=='1'}}"><view class="cu-tag bg-orange sm margin-left-sm data-v-b41f5bda">默认</view></block>{{''+item.provinceName+item.cityName+item.countyName+item.detailInfo+''}}</view></view><view data-event-opts="{{[['tap',[['toEdit',[index]]]]]}}" class="action data-v-b41f5bda" bindtap="__e"><text class="cuIcon-edit data-v-b41f5bda"></text></view></view></block></view><view class="{{['cu-load','bg-gray','data-v-b41f5bda',loadmore?'loading':'']}}"></view><block wx:if="{{$root.g0}}"><view class="cu-load bg-gray margin-top-xl data-v-b41f5bda"><text class="text-gray data-v-b41f5bda">暂无收货地址，请添加</text></view></block><block wx:if="{{$root.g1<10}}"><button data-event-opts="{{[['tap',[['toAdd',['$event']]]]]}}" class="cu-btn block shadow-blur margin-sm data-v-b41f5bda" style="background-color:#2967ff;font-weight:300;height:88rpx;margin-top:200rpx;" bindtap="__e"><text class="text-white data-v-b41f5bda">添加新地址</text></button></block></view>