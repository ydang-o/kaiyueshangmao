<view class="padding data-v-fa1b4336"><view class="bg-white padding radius shadow-lg data-v-fa1b4336"><view class="text-center margin-bottom-lg data-v-fa1b4336"><view class="text-xxl text-bold text-red data-v-fa1b4336">积分红包</view><view class="text-gray margin-top-sm data-v-fa1b4336">赠送积分给好友</view><view class="margin-top-sm text-lg data-v-fa1b4336">当前可用积分：<text class="text-orange text-bold data-v-fa1b4336">{{userInfo.points||0}}</text></view></view><view class="data-v-fa1b4336"><view class="cu-form-group margin-top data-v-fa1b4336"><view class="title data-v-fa1b4336">接收方手机</view><input placeholder="请输入接收方手机号" type="number" maxlength="11" data-event-opts="{{[['input',[['__set_model',['','phone','$event',[]]]]]]}}" value="{{phone}}" bindinput="__e" class="data-v-fa1b4336"/></view><view class="cu-form-group data-v-fa1b4336"><view class="title data-v-fa1b4336">赠送数量</view><input placeholder="请输入积分数量" type="number" data-event-opts="{{[['input',[['__set_model',['','amount','$event',[]]]]]]}}" value="{{amount}}" bindinput="__e" class="data-v-fa1b4336"/></view><view class="cu-form-group data-v-fa1b4336"><view class="title data-v-fa1b4336">验证码</view><input placeholder="短信验证码" type="number" maxlength="6" data-event-opts="{{[['input',[['__set_model',['','code','$event',[]]]]]]}}" value="{{code}}" bindinput="__e" class="data-v-fa1b4336"/><button class="cu-btn bg-green shadow data-v-fa1b4336" disabled="{{smsDisabled}}" data-event-opts="{{[['tap',[['sendSms',['$event']]]]]}}" bindtap="__e">{{smsText}}</button></view><view class="padding flex flex-direction margin-top-xl data-v-fa1b4336"><button class="cu-btn bg-red margin-tb-sm lg data-v-fa1b4336" loading="{{loading}}" data-event-opts="{{[['tap',[['sendPacket',['$event']]]]]}}" bindtap="__e">确认发送</button></view></view><view class="text-gray text-sm padding-lr margin-top data-v-fa1b4336"><view class="data-v-fa1b4336">说明：</view><view class="data-v-fa1b4336">1. 接收方必须是平台注册会员。</view><view class="data-v-fa1b4336">2. 发送前请确认您的积分余额充足。</view><view class="data-v-fa1b4336">3. 验证码将发送至您当前绑定的手机号。</view></view></view></view>