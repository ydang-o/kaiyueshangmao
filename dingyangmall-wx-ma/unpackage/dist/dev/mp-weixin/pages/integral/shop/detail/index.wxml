<block wx:if="{{goodsDetail}}"><view class="page tm-page data-v-053d16ba"><view class="goods-swiper data-v-053d16ba"><swiper class="screen-swiper data-v-053d16ba" indicator-dots="{{true}}" circular="{{true}}" autoplay="{{true}}" interval="{{5000}}" duration="{{500}}"><block wx:for="{{$root.l0}}" wx:for-item="pic" wx:for-index="i" wx:key="i"><swiper-item class="data-v-053d16ba"><image class="swiper-image data-v-053d16ba" src="{{pic.m0}}" mode="aspectFill"></image></swiper-item></block></swiper><view class="page-index data-v-053d16ba">{{currentSwiper+"/"+$root.g0}}</view></view><view class="goods-info bg-white padding data-v-053d16ba"><view class="integral-price data-v-053d16ba"><text class="integral-num data-v-053d16ba">{{goodsDetail.salesPrice}}</text><text class="integral-unit data-v-053d16ba">积分</text></view><view class="goods-name text-xl text-bold margin-top-sm data-v-053d16ba">{{goodsDetail.name}}</view><block wx:if="{{goodsDetail.description}}"><view class="goods-desc text-gray margin-top-sm data-v-053d16ba">{{goodsDetail.description}}</view></block><view class="goods-stock text-gray margin-top-sm data-v-053d16ba"><text class="data-v-053d16ba">{{"库存："+(goodsDetail.stock||0)+"件"}}</text><text class="margin-left data-v-053d16ba">{{"已兑换："+(goodsDetail.salesNum||0)+"件"}}</text></view></view><view class="goods-detail bg-white margin-top-sm data-v-053d16ba"><view class="cu-bar data-v-053d16ba"><view class="action data-v-053d16ba"><text class="cuIcon-titles text-red data-v-053d16ba"></text><text class="data-v-053d16ba">商品详情</text></view></view><view class="padding data-v-053d16ba"><rich-text nodes="{{goodsDetail.detail||goodsDetail.content||'暂无详情'}}" class="data-v-053d16ba"></rich-text></view></view><view class="exchange-notice bg-white margin-top-sm data-v-053d16ba"><view class="cu-bar data-v-053d16ba"><view class="action data-v-053d16ba"><text class="cuIcon-titles text-blue data-v-053d16ba"></text><text class="data-v-053d16ba">兑换须知</text></view></view><view class="padding text-gray data-v-053d16ba"><view class="notice-item data-v-053d16ba">1. 请确认您的积分余额充足</view><view class="notice-item margin-top-xs data-v-053d16ba">2. 兑换成功后不支持退换</view><view class="notice-item margin-top-xs data-v-053d16ba">3. 实物商品将在3个工作日内发货</view><view class="notice-item margin-top-xs data-v-053d16ba">4. 虚拟商品将自动发放到账户</view></view></view><view class="cu-bar bg-white tabbar border foot data-v-053d16ba"><view class="integral-info data-v-053d16ba"><text class="text-gray data-v-053d16ba">我的积分：</text><text class="integral-num data-v-053d16ba">{{userInfo.points||0}}</text></view><view class="btn-group data-v-053d16ba"><button class="cu-btn tm-primary-btn exchange-btn data-v-053d16ba" disabled="{{(userInfo.points||0)<goodsDetail.salesPrice||(goodsDetail.stock||0)<=0}}" data-event-opts="{{[['tap',[['showExchangeModal',['$event']]]]]}}" bindtap="__e">{{''+((goodsDetail.stock||0)<=0?'已兑完':'立即兑换')+''}}</button></view></view><view class="{{['cu-modal','data-v-053d16ba',showModal?'show':'']}}"><view class="cu-dialog data-v-053d16ba"><view class="cu-bar bg-white justify-end data-v-053d16ba"><view class="content data-v-053d16ba">确认兑换</view><view data-event-opts="{{[['tap',[['hideExchange',['$event']]]]]}}" class="action data-v-053d16ba" bindtap="__e"><text class="cuIcon-close text-red data-v-053d16ba"></text></view></view><view class="padding-xl data-v-053d16ba"><view class="exchange-info data-v-053d16ba"><text class="data-v-053d16ba">商品：</text><text class="text-bold data-v-053d16ba">{{goodsDetail.name}}</text></view><view class="exchange-info margin-top data-v-053d16ba"><text class="data-v-053d16ba">所需积分：</text><text class="integral-num data-v-053d16ba">{{goodsDetail.salesPrice}}</text></view><view class="exchange-info margin-top data-v-053d16ba"><text class="data-v-053d16ba">当前积分：</text><text class="{{['data-v-053d16ba',(userInfo.points||0)>=goodsDetail.salesPrice?'text-green':'text-red']}}">{{userInfo.points||0}}</text></view><block wx:if="{{goodsDetail.type==='physical'}}"><view class="address-section margin-top data-v-053d16ba"><view class="section-title data-v-053d16ba">选择收货地址</view><block wx:if="{{selectedAddress}}"><view data-event-opts="{{[['tap',[['selectAddress',['$event']]]]]}}" class="address-card data-v-053d16ba" bindtap="__e"><view class="address-info data-v-053d16ba"><view class="user-info data-v-053d16ba"><text class="name data-v-053d16ba">{{selectedAddress.userName}}</text><text class="phone data-v-053d16ba">{{selectedAddress.telNum}}</text></view><view class="address-text data-v-053d16ba">{{selectedAddress.address}}</view></view><text class="cuIcon-right text-gray data-v-053d16ba"></text></view></block><block wx:else><view data-event-opts="{{[['tap',[['selectAddress',['$event']]]]]}}" class="no-address data-v-053d16ba" bindtap="__e"><text class="cuIcon-add text-green data-v-053d16ba"></text><text class="data-v-053d16ba">请选择收货地址</text></view></block></view></block></view><view class="cu-bar bg-white justify-end data-v-053d16ba"><view class="action data-v-053d16ba"><button data-event-opts="{{[['tap',[['hideExchange',['$event']]]]]}}" class="cu-btn line-green text-green data-v-053d16ba" bindtap="__e">取消</button><button class="cu-btn bg-green margin-left data-v-053d16ba" loading="{{exchanging}}" data-event-opts="{{[['tap',[['confirmExchange',['$event']]]]]}}" bindtap="__e">确认兑换</button></view></view></view></view></view></block>