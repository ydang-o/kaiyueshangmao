<view class="container tm-page data-v-a8e01db4"><view class="header data-v-a8e01db4"><view class="title data-v-a8e01db4">幸运大抽奖</view><block wx:if="{{config.costPoints}}"><view class="sub-title data-v-a8e01db4">{{"消耗 "+config.costPoints+" 积分/次"}}</view></block><view class="points data-v-a8e01db4">{{"我的积分: "+(userInfo.points||0)}}</view><block wx:if="{{config.dailyLimit}}"><view class="limit data-v-a8e01db4">{{"每日限抽: "+config.dailyLimit+" 次"}}</view></block></view><view class="wheel-area data-v-a8e01db4"><button class="draw-btn data-v-a8e01db4" disabled="{{loading}}" data-event-opts="{{[['tap',[['handleDraw',['$event']]]]]}}" bindtap="__e">{{loading?'抽奖中...':'立即抽奖'}}</button></view><block wx:if="{{$root.g0}}"><view class="prize-list data-v-a8e01db4"><view class="section-title data-v-a8e01db4">奖品列表</view><view class="prize-grid data-v-a8e01db4"><block wx:for="{{config.prizeList}}" wx:for-item="item" wx:for-index="i" wx:key="i"><view class="prize-item data-v-a8e01db4"><image class="prize-img data-v-a8e01db4" src="{{item.prizePic||'/static/img/no_pic.png'}}" mode="aspectFit"></image><view class="prize-name data-v-a8e01db4">{{item.prizeName}}</view></view></block></view></view></block><view class="record-list data-v-a8e01db4"><view class="section-title data-v-a8e01db4">我的中奖记录</view><block wx:for="{{recordList}}" wx:for-item="item" wx:for-index="i" wx:key="i"><view class="record-item data-v-a8e01db4"><text class="time data-v-a8e01db4">{{item.createTime}}</text><text class="name data-v-a8e01db4">{{item.prizeName}}</text><text class="status data-v-a8e01db4">{{item.grantStatus=='1'?'已发放':'待发放'}}</text></view></block><block wx:if="{{$root.g1===0}}"><view class="empty data-v-a8e01db4">暂无记录</view></block></view></view>