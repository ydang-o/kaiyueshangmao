/* 组件 wxss 不允许标签/ID/属性选择器，故不引入 main.wxss；仅保留本组件用到的图标字体与 class */
@font-face {
  font-family: "cuIcon";
  src: url('//at.alicdn.com/t/font_533566_yfq2d9wdij.ttf?t=1545239985831') format('truetype');
}
.tab-item .icon {
  font-family: "cuIcon";
  font-size: inherit;
  font-style: normal;
}
.cuIcon-home:before { content: "\e6b8"; }
.cuIcon-homefill:before { content: "\e6bb"; }
.cuIcon-apps:before { content: "\e729"; }
.cuIcon-cart:before { content: "\e6af"; }
.cuIcon-cartfill:before { content: "\e6b9"; }
.cuIcon-my:before { content: "\e78b"; }
.cuIcon-myfill:before { content: "\e78c"; }

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 130rpx;
  min-height: 130rpx;
  padding: 16rpx 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 9999;
  box-sizing: border-box;
  /* 仅底部一条栏可点，不遮挡页面内容 */
  pointer-events: none;
}

.tab-bar .tab-item {
  pointer-events: auto;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
}

.tab-item .icon {
  font-size: 52rpx;
  margin-bottom: 8rpx;
  color: #9ca3af;
  transition: color 0.2s;
}

.tab-item .text {
  font-size: 24rpx;
  color: #9ca3af;
  transition: color 0.2s;
}

.tab-item.active .icon,
.tab-item.active .text {
  color: #ff0036;
}

.tab-item.active .text {
  font-weight: 600;
}

.tab-item-icon-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-bar-badge {
  position: absolute;
  top: -8rpx;
  right: 50%;
  margin-right: -48rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  font-size: 20rpx;
  color: #fff;
  background: #ff0036;
  border-radius: 16rpx;
  text-align: center;
  box-sizing: border-box;
}
