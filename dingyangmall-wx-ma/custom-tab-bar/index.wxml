<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <text class="icon {{selected === index ? item.iconActive : item.icon}}"></text>
    <text class="text">{{item.text}}</text>
  </view>
</view>
